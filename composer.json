{
  "name": "pylon/arcos-cli",
  "description": "ARCOS CLI - developer tooling for ARCOS projects",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "pylon/arcos": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Arcos\\Cli\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Arcos\\Cli\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/arcos",
    "bin/arcos.bat"
  ],
  "scripts": {
    "test": "phpunit --testsuite unit,support",
    "test:unit": "phpunit --testsuite unit",
    "test:support": "phpunit --testsuite support",
    "test:fixtures": "phpunit --testsuite fixtures"
  }
}